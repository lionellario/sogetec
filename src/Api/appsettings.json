{
  "AllowedHosts": "*",
  "Aspire": {
    "StackExchange": {
      "Redis": {
        "ConfigurationOptions": {
          "ConnectRetry": 5,
          "ConnectTimeout": 3000
        }
      }
    }
  },
  "RateLimiter": {
    "FixedWindowRateLimiter": {
      "PermitLimit": 50,
      "QueueLimit": 0,
      "Window": "00:01:00"
    },
    "TokenBucketRateLimiter": {
      "QueueLimit": 5,
      "ReplenishmentPeriod": "00:00:10",
      "TokenLimit": 30,
      "TokensPerPeriod": 30
    }
  },
  "Caching": {
    "Expiration": "00:30:00",
    "MaximumPayloadBytes": 10485760
  },
  "Logging": {
    "GlobalLogBuffering": {
      "AutoFlushDuration": "00:00:30",
      "MaxBufferSizeInBytes": 104857600,
      "MaxLogRecordSizeInBytes": 51200,
      "Rules": [
        {
          "CategoryName": "Polly",
          "LogLevel": "Information"
        }
      ]
    },
    "PerIncomingRequestLogBuffering": {
      "AutoFlushDuration": "00:00:05",
      "Rules": [
        {
          "LogLevel": "Information"
        }
      ]
    },
    "RandomProbabilisticSampler": {
      "Rules": [
        {
          "CategoryName": "XXXX.*",
          "LogLevel": "Information",
          "Probability": 0.25
        },
        {
          "CategoryName": "Microsoft.AspNetCore.*",
          "LogLevel": "Information",
          "Probability": 0.1
        },
        {
          "CategoryName": "System.*",
          "Probability": 0.1
        }
      ]
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.File", "Serilog.Sinks.OpenTelemetry"],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
        "Microsoft.AspNetCore.HttpLogging.HttpLoggingMiddleware": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "path": "Logs/log-.json",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "fileSizeLimitBytes": 104857600,
          "retainedFileCountLimit": 14
        }
      },
      {
        "Name": "OpenTelemetry"
      }
    ]
  }
}
