# Bind mount source for keycloak:/opt/keycloak/data/import
KEYCLOAK_BINDMOUNT_0=

# Bind mount source for keycloak:/opt/keycloak/realm-import/
KEYCLOAK_BINDMOUNT_1=

# Parameter keycloak-password
KEYCLOAK_PASSWORD=

# Parameter postgres-password
POSTGRES_PASSWORD=

# Parameter redis
REDIS=

# Container image name for sogetec-admin
SOGETEC_ADMIN_IMAGE=

# Parameter Sogetec-admin-url
SOGETEC_ADMIN_URL=

# Container image name for sogetec-api
SOGETEC_API_IMAGE=

# Default container port for sogetec-api
SOGETEC_API_PORT=

# Parameter sogetec-api-secret
SOGETEC_API_SECRET=

# Container image name for sogetec-frontend
SOGETEC_FRONTEND_IMAGE=

# Parameter Sogetec-spa-url
SOGETEC_SPA_URL=

# Parameter sogetecdb
SOGETECDB=

